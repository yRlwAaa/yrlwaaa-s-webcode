<script>
	(function() {
		const loginPage = document.getElementById('login-page');
		const appContent = document.getElementById('swup-container');

		// 直接用 cookie 检测登录状态
		function isLoggedIn() {
			const cookies = document.cookie.split(';');
			for (let cookie of cookies) {
				if (cookie.trim() === 'cf_auth=1') {
					return true;
				}
			}
			return false;
		}

		function showLoginPage() {
			if (loginPage) loginPage.style.display = 'flex';
			if (appContent) appContent.style.display = 'none';
			const player = document.querySelector('.music-player');
			if (player) player.style.display = 'none';
			const controls = document.querySelector('.floating-controls-container');
			if (controls) controls.style.display = 'none';
		}

		function showAppContent() {
			if (loginPage) loginPage.style.display = 'none';
			if (appContent) appContent.style.display = 'block';
			const player = document.querySelector('.music-player');
			if (player) player.style.display = 'block';
			const controls = document.querySelector('.floating-controls-container');
			if (controls) controls.style.display = 'block';
		}

		// 登录函数 - 直接用预设账号
		async function handleLogin() {
			const email = document.getElementById('login-email').value.trim();
			const password = document.getElementById('login-password').value.trim();
			const errorEl = document.getElementById('login-error');
			const btn = document.getElementById('login-btn');

			if (!email || !password) {
				errorEl.style.display = 'block';
				errorEl.textContent = '请输入邮箱和密码';
				return;
			}

			errorEl.style.display = 'none';
			btn.textContent = '登录中...';
			btn.disabled = true;

			// 预设账号：admin@test.com / 123456
			if (email === 'admin@test.com' && password === '123456') {
				document.cookie = 'cf_auth=1; path=/; max-age=86400';
				showAppContent();
				window.location.reload();
			} else {
				errorEl.style.display = 'block';
				errorEl.textContent = '邮箱或密码错误';
				btn.textContent = '登录';
				btn.disabled = false;
			}
		}

		// 检查登录状态
		if (isLoggedIn()) {
			showAppContent();
		} else {
			showLoginPage();
		}

		// 监听页面切换，重新检测登录状态
		document.addEventListener('visibilitychange', function() {
			if (!document.hidden) {
				if (isLoggedIn()) {
					showAppContent();
				} else {
					showLoginPage();
				}
			}
		});

		// 绑定登录按钮
		document.getElementById('login-btn').addEventListener('click', handleLogin);
		document.getElementById('login-password').addEventListener('keydown', function(e) {
			if (e.key === 'Enter') handleLogin();
		});
		document.getElementById('login-email').addEventListener('keydown', function(e) {
			if (e.key === 'Enter') handleLogin();
		});

		console.log('登录系统已加载，测试账号: admin@test.com / 123456');
	})();
</script>