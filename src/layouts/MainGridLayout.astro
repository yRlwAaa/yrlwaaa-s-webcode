---
import FloatingControls from "@components/control/FloatingControls.astro";
import { SidebarTOC } from "@components/features/toc";
import Banner from "@components/layout/Banner.astro";
import RightSideBar from "@components/layout/RightSideBar.astro";
import FullscreenWallpaper from "@components/misc/FullscreenWallpaper.astro";
import IconifyLoader from "@components/misc/IconifyLoader.astro";
import Footer from "@components/organisms/footer/Footer.astro";
import Navbar from "@components/organisms/navigation/Navbar.astro";
import SideBar from "@components/widgets/sidebar/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";

import { fullscreenWallpaperConfig, siteConfig } from "../config";
import { BANNER_HEIGHT } from "../constants/constants";
import {
	calculateGridLayout,
	getBannerImages,
	getMainPanelTop,
	getTransparencyClass,
	shouldEnableTransparency,
} from "../utils/grid-layout-utils";
import { widgetManager } from "../utils/widget-manager";
import Layout from "./Layout.astro";
import GridScripts from "./partials/GridScripts.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
	headings?: MarkdownHeading[];
}

// 获取 banner 图片
const bannerImages = await getBannerImages(siteConfig);

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	postSlug,
	headings = [],
} = Astro.props;
const hasBannerCredit = siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

// 检查是否为首页
const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";
// 手机端非首页不显示banner的CSS类
const mobileNonHomeBannerClass = !isHomePage ? "mobile-hide-banner" : "";

// 计算主内容区域位置
const finalMainPanelTop = getMainPanelTop(
	siteConfig.wallpaperMode.defaultMode,
	BANNER_HEIGHT,
);

// 计算网格布局
const {
	gridCols,
	sidebarClass,
	rightSidebarClass,
	mainContentClass,
	sidebarPresence,
	mobileShowSidebar,
	tabletShowSidebar,
	desktopShowSidebar,
} = calculateGridLayout({
	siteConfig,
	widgetManager,
});

const { hasRightSidebarComponents, hasMobileDrawerComponents } =
	sidebarPresence;

// 半透明效果
const shouldEnable = shouldEnableTransparency(
	siteConfig.wallpaperMode.defaultMode,
);
const transparentClass = getTransparencyClass(shouldEnable);

// 布局模式
const defaultPostListLayout = siteConfig.postListLayout?.defaultMode || "list";
---

<Layout
	title={title}
	banner={banner}
	description={description}
	lang={lang}
	setOGTypeArticle={setOGTypeArticle}
	postSlug={postSlug}
>
	<GridScripts
		navbarTransparentMode={siteConfig.banner?.navbar?.transparentMode ||
			"semi"}
		defaultWallpaperMode={siteConfig.wallpaperMode.defaultMode}
		defaultPostListLayout={siteConfig.postListLayout?.defaultMode || "list"}
		BANNER_HEIGHT={BANNER_HEIGHT}
		pageScaling={siteConfig.pageScaling}
	/>

	<!-- 全屏壁纸 - 始终渲染，通过 JS 控制显示隐藏 -->
	<FullscreenWallpaper config={fullscreenWallpaperConfig} />

	<!-- 全局图标加载器 -->
	<IconifyLoader />

	<!-- Navbar -->
	<slot slot="head" name="head" />
	<div
		id="top-row"
		class="z-50 pointer-events-none relative transition-all duration-700 max-w-(--page-width) px-0 md:px-4 mx-auto"
		class:list={[""]}
	>
		<div
			id="navbar-wrapper"
			class="pointer-events-auto sticky top-0 transition-all"
		>
			<Navbar />
		</div>
	</div>

	<!-- Banner 组件 -->
	<Banner
		bannerImages={bannerImages}
		mobileNonHomeBannerClass={mobileNonHomeBannerClass}
		showTextOverlay={isHomePage &&
			(siteConfig.banner.homeText?.enable ?? false)}
	/>

	<!-- Main content -->
	<div
		class={`absolute w-full z-30 pointer-events-none ${mobileNonHomeBannerClass ? "mobile-main-no-banner" : ""} ${siteConfig.wallpaperMode.defaultMode === "none" ? "no-banner-layout" : ""} ${transparentClass}`}
		style={`top: ${finalMainPanelTop}`}
	>
		<div class="relative max-w-(--page-width) mx-auto pointer-events-auto">
			<div
				id="main-grid"
				class={`transition duration-700 w-full left-0 right-0 grid ${gridCols} grid-rows-none md:grid-rows-[auto] mx-auto gap-4 px-2 md:px-4 ${!mobileShowSidebar || !hasMobileDrawerComponents ? "mobile-no-sidebar" : ""} ${hasRightSidebarComponents ? "mobile-both-sidebar" : ""}`}
				data-layout-mode={defaultPostListLayout}
			>
				{
					hasBannerCredit && (
						<a
							href={siteConfig.banner.credit.url}
							id="banner-credit"
							target="_blank"
							rel="noopener"
							aria-label="Visit image source"
							class:list={[
								"group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
									"px-3 right-4 -top-13 bg-black/60 hover:bg-black/70 h-9",
								{
									"hover:pr-9 active:bg-black/80":
										hasBannerLink,
								},
							]}
						>
							<Icon
								class="text-white/75 text-[1.25rem] mr-1"
								name="material-symbols:copyright-outline-rounded"
							/>
							<div class="text-white/75 text-xs">
								{siteConfig.banner.credit.text}
							</div>
							<Icon
								class:list={[
									"transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
									{
										"group-hover:opacity-100":
											hasBannerLink,
									},
								]}
								name="fa7-solid:arrow-up-right-from-square"
							/>
						</a>
					)
				}

				<div class="contents">
					{
						(mobileShowSidebar ||
							tabletShowSidebar ||
							desktopShowSidebar) && (
							<SideBar
								class={`${sidebarClass} ${transparentClass}`}
								headings={headings}
							/>
						)
					}

					{
						hasRightSidebarComponents && (
							<div
								class={`right-sidebar-container ${rightSidebarClass} ${transparentClass}`}
							>
								<RightSideBar headings={headings} />
							</div>
						)
					}
				</div>

				<main
					id="swup-container"
					class={`${mainContentClass} transition-main`}
				>
					<div
						id="content-wrapper"
						class="onload-animation transition-leaving"
					>
						<slot />
						<div
							class="footer col-span-full onload-animation hidden lg:block"
						>
							<Footer />
						</div>
					</div>
				</main>

				<div
					class="footer col-span-full onload-animation block lg:hidden"
				>
					<Footer />
				</div>
			</div>

			<FloatingControls headings={headings} />
		</div>
	</div>

	<style>
		.right-sidebar-container {
			align-self: start;
			display: contents;
		}

		.right-sidebar-container #right-sidebar {
			height: fit-content;
		}
	</style>

	{
		siteConfig.toc.enable && siteConfig.toc.desktopSidebar && (
			<div class="absolute w-full z-0 hidden 2xl:block">
				<div class="relative max-w-(--page-width) mx-auto">
					<div
						id="toc-wrapper"
						class:list={[
							"hidden lg:block transition absolute top-0 w-(--toc-width) items-center",
							"-right-(--toc-width)",
							{
								"toc-hide":
									siteConfig.wallpaperMode.defaultMode ===
									"banner",
							},
						]}
					>
						<div
							id="toc-inner-wrapper"
							class="fixed top-14 w-(--toc-width) h-[calc(100vh-6rem)] max-h-[calc(100vh-6rem)] overflow-x-hidden overflow-y-auto"
						>
							<div
								id="toc-container"
								class="w-full h-full transition-swup-fade"
							>
								<SidebarTOC headings={headings} />
							</div>
						</div>
					</div>
				</div>
			</div>
		)
	}

	{
		(!siteConfig.toc.enable || !siteConfig.toc.desktopSidebar) && (
			<div id="toc-container" class="hidden" />
		)
	}

	<!-- ============================================ -->
	<!-- 登录界面 -->
	<!-- ============================================ -->
	<div id="login-page" style="display:flex; position:fixed; top:0; left:0; right:0; bottom:0; z-index:99999; background:linear-gradient(145deg, #f0f2f5 0%, #ffffff 100%); align-items:center; justify-content:center;">
		<div style="background:rgba(255,255,255,0.85); backdrop-filter:blur(20px); padding:48px 40px 40px; border-radius:28px; max-width:420px; width:90%; box-shadow:0 30px 80px rgba(0,0,0,0.12); border:1px solid rgba(0,0,0,0.06);">
			<div style="text-align:center; margin-bottom:24px;">
				<div style="width:72px; height:72px; border-radius:50%; background:linear-gradient(135deg, #4a90d9, #6cb2eb); margin:0 auto 12px; display:flex; align-items:center; justify-content:center; font-size:32px; box-shadow:0 8px 24px rgba(74,144,217,0.25);">🌸</div>
				<h2 style="margin:0; font-size:22px; font-weight:700; color:#1a1a1a;">欢迎回来</h2>
				<p style="margin:4px 0 0; font-size:14px; color:#888;">登录以继续</p>
			</div>
			<div id="login-error" style="display:none; background:rgba(239,68,68,0.08); color:#dc2626; padding:10px 14px; border-radius:12px; font-size:13px; margin-bottom:16px; border:1px solid rgba(239,68,68,0.15);"></div>
			<input id="login-email" type="email" placeholder="邮箱地址" value="admin@test.com" style="width:100%; padding:14px 16px; margin-bottom:12px; border:2px solid #e5e7eb; border-radius:14px; font-size:15px; background:#f8fafc; color:#1a1a1a; box-sizing:border-box; outline:none;">
			<input id="login-password" type="password" placeholder="密码" value="123456" style="width:100%; padding:14px 16px; margin-bottom:8px; border:2px solid #e5e7eb; border-radius:14px; font-size:15px; background:#f8fafc; color:#1a1a1a; box-sizing:border-box; outline:none;" onkeydown="if(event.key==='Enter') document.getElementById('login-btn').click();">
			<button id="login-btn" onclick="doLogin()" style="width:100%; padding:14px; background:linear-gradient(135deg, #4a90d9, #3b7bc8); color:white; border:none; border-radius:14px; font-size:16px; font-weight:600; cursor:pointer; box-shadow:0 4px 16px rgba(74,144,217,0.25);">登录</button>
			<p style="text-align:center; font-size:14px; color:#666; margin-top:20px;">还没有账号？<a href="/signup" style="color:#4a90d9; text-decoration:none; font-weight:500;">立即注册</a></p>
		</div>
	</div>

	<script>
		window.doLogin = function() {
			var email = document.getElementById('login-email').value.trim();
			var password = document.getElementById('login-password').value.trim();
			var errorEl = document.getElementById('login-error');

			if (!email || !password) {
				errorEl.style.display = 'block';
				errorEl.textContent = '请输入邮箱和密码';
				return;
			}

			errorEl.style.display = 'none';

			if (email === 'admin@test.com' && password === '123456') {
				document.cookie = 'cf_auth=1; path=/; max-age=86400';
				localStorage.setItem('cf_auth', '1');
				document.getElementById('login-page').style.display = 'none';
				window.location.reload();
			} else {
				errorEl.style.display = 'block';
				errorEl.textContent = '邮箱或密码错误';
			}
		};

		// 检查登录状态
		(function() {
			var cookies = document.cookie.split(';');
			var isLoggedIn = false;
			for (var i = 0; i < cookies.length; i++) {
				if (cookies[i].trim() === 'cf_auth=1') {
					isLoggedIn = true;
					break;
				}
			}
			if (isLoggedIn) {
				document.getElementById('login-page').style.display = 'none';
			}
		})();

		console.log('✅ 登录系统已加载');
		console.log('📧 测试账号: admin@test.com');
		console.log('🔑 测试密码: 123456');
	</script>

</Layout>