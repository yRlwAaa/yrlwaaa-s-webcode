---
// src/pages/login.astro
---

<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>登录</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:system-ui,-apple-system,sans-serif;background:linear-gradient(145deg,#f0f2f5,#fff);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:16px}
    .card{background:rgba(255,255,255,0.85);backdrop-filter:blur(20px);padding:40px 36px;border-radius:28px;max-width:400px;width:100%;box-shadow:0 30px 80px rgba(0,0,0,0.1);border:1px solid rgba(0,0,0,0.05)}
    .avatar{width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#4a90d9,#6cb2eb);margin:0 auto 16px;display:flex;align-items:center;justify-content:center;font-size:32px;box-shadow:0 8px 24px rgba(74,144,217,0.25)}
    h2{text-align:center;font-size:22px;font-weight:700;color:#1a1a1a}
    .sub{text-align:center;font-size:14px;color:#888;margin-bottom:24px}
    .error{display:none;background:rgba(239,68,68,0.08);color:#dc2626;padding:10px 14px;border-radius:12px;font-size:13px;margin-bottom:16px;border:1px solid rgba(239,68,68,0.15)}
    input{width:100%;padding:14px 16px;margin-bottom:12px;border:2px solid #e5e7eb;border-radius:14px;font-size:15px;background:#f8fafc;color:#1a1a1a;outline:none;box-sizing:border-box;transition:border-color .2s}
    input:focus{border-color:#4a90d9;box-shadow:0 0 0 4px rgba(74,144,217,0.1)}
    button{width:100%;padding:14px;background:linear-gradient(135deg,#4a90d9,#3b7bc8);color:#fff;border:none;border-radius:14px;font-size:16px;font-weight:600;cursor:pointer;box-shadow:0 4px 16px rgba(74,144,217,0.25);transition:opacity .2s}
    button:hover{opacity:.9}
    .signup{text-align:center;font-size:14px;color:#666;margin-top:20px}
    .signup a{color:#4a90d9;text-decoration:none;font-weight:500}
  </style>
</head>
<body>
  <div class="card">
    <div class="avatar">🌸</div>
    <h2>欢迎回来</h2>
    <p class="sub">登录以继续</p>
    <div id="login-error" class="error"></div>
    <input id="login-email" type="email" placeholder="邮箱地址" value="admin@test.com" />
    <input id="login-password" type="password" placeholder="密码" value="123456" />
    <button id="login-btn">登录</button>
    <p class="signup">还没有账号？<a href="/signup">立即注册</a></p>
  </div>

  <script>
    (function() {
      const btn = document.getElementById('login-btn');
      const emailInput = document.getElementById('login-email');
      const pwdInput = document.getElementById('login-password');
      const errorEl = document.getElementById('login-error');

      function doLogin() {
        const email = emailInput.value.trim();
        const password = pwdInput.value.trim();

        if (!email || !password) {
          errorEl.style.display = 'block';
          errorEl.textContent = '请输入邮箱和密码';
          return;
        }
        errorEl.style.display = 'none';

        if (email === 'admin@test.com' && password === '123456') {
          document.cookie = 'cf_auth=1; path=/; max-age=86400';
          window.location.href = '/';
        } else {
          errorEl.style.display = 'block';
          errorEl.textContent = '邮箱或密码错误';
        }
      }

      btn.addEventListener('click', doLogin);
      pwdInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') doLogin(); });
      emailInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') doLogin(); });
    })();
  </script>
</body>
</html>